{
  "expo": {
    "name": "Klyro",
    "slug": "client-talksy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/KlyroLightLogo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/KlyroLightLogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.talksy.chat",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/KlyroLightLogo.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "NOTIFICATIONS",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/KlyroLightLogo.png",
          "color": "#C4734A"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "593f69ca-2eeb-4e1b-8a6c-4569f6cf92bb"
      }
    },
    "owner": "ayush2133k"
  }
}