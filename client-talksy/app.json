{
  "expo": {
    "name": "Talksy",
    "slug": "client-talksy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/TalksyAppIcon.png",
    "userInterfaceStyle": "light",

    "splash": {
      "image": "./assets/TalksySS.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },

    "ios": {
      "supportsTablet": true
    },

    "android": {
      "package": "com.talksy.chat",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/TalksyAppIcon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "NOTIFICATIONS",
        "VIBRATE"
      ]
    },

    "web": {
      "favicon": "./assets/favicon.png"
    },

    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/TalksyAppIcon.png",
          "color": "#25D366"
        }
      ],
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "Allow Talksy to access your camera for video calls.",
          "microphonePermission": "Allow Talksy to access your microphone for audio/video calls."
        }
      ]
    ],

    "extra": {
      "eas": {
        "projectId": "593f69ca-2eeb-4e1b-8a6c-4569f6cf92bb"
      }
    },

    "owner": "ayush2133k"
  }
}